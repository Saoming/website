---
import Divider from "../../components/common/Divider.astro";
import SingleCaseStudies from "../../components/sections/SingleCaseStudies.astro";
import CaseStudiesHoverPreview from "../../components/sections/CaseStudiesHoverPreview.astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = await getCollection("projects");
// Single ordered list: row index === filmstrip frame index.
const items = projects.map((p) => p.data);
---

<BaseLayout
  footer="simple"
  title="Case Studies"
  description="Selected client work — WordPress, Shopify, Framer and custom builds by Samuel Tirtawidjaja."
>
  <!-- Hover/scope boundary. pointerout past this edge closes the box. -->
  <div data-cs-list>
    {
      items.map(({ id, slug, title, categories }, index) => (
        <>
          <SingleCaseStudies
            id={id}
            slug={slug}
            title={title}
            categories={categories}
            index={index}
          />
          <Divider caseStudies={true} />
        </>
      ))
    }
  </div>

  <!-- One persistent floating preview, fed the SAME ordered array. -->
  <CaseStudiesHoverPreview projects={items} />
</BaseLayout>
