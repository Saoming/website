---
import CaseStudyCard from "./CaseStudyCard.astro";
import projectsData from "../../projects/projects.json";

type Project = {
  id: number;
  slug: string;
  title: string;
  categories: string[];
};

const projects = projectsData.projects as Project[];
const project = (id: number) => projects.find((p) => p.id === id);

// Optimized cover images, resolved by slug (filename === slug)
const covers = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/case-studies/*.{png,jpg,jpeg,webp}",
  { eager: true }
);
const cover = (slug: string) => covers[`../assets/case-studies/${slug}.png`].default;

const icebaths = project(1);
const rogershood = project(2);
const sheaco = project(3);
const stacey = project(4);
---

<section class="container flex flex-col pt-[60px] pb-[40px] lg:pt-[135px] lg:pb-[80px]">
  <h2 class="font-pp-seiko uppercase text-[38px] lg:text-[86px] mb-[60px] lg:mb-[90px]">
    Case <span class="font-neue-montreal triangle-text-after">Studies</span>
  </h2>

  <div class="flex flex-col gap-y-[60px] lg:gap-y-[120px]">
    <!-- Row 1 — large left, narrow right (raised) -->
    <div
      class="flex flex-col gap-y-[60px] lg:grid lg:grid-cols-12 lg:gap-x-[40px] lg:items-start"
    >
      <div class="lg:col-span-7">
        {icebaths && <CaseStudyCard {...icebaths} image={cover(icebaths.slug)} />}
      </div>
      <div class="lg:col-span-4 lg:col-start-9 lg:-mt-[200px]">
        {rogershood && <CaseStudyCard {...rogershood} image={cover(rogershood.slug)} />}
      </div>
    </div>

    <!-- Row 2 — narrow left, large right -->
    <div
      class="flex flex-col gap-y-[60px] lg:grid lg:grid-cols-12 lg:gap-x-[40px] lg:items-start"
    >
      <div class="lg:col-span-4">
        {sheaco && <CaseStudyCard {...sheaco} image={cover(sheaco.slug)} />}
      </div>
      <div class="lg:col-span-7 lg:col-start-6">
        {stacey && <CaseStudyCard {...stacey} image={cover(stacey.slug)} />}
      </div>
    </div>
  </div>
</section>
