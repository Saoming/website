---
import Divider from "../../common/Divider.astro";
---

<Divider caseStudies={true} />
<section class="container py-[40px] md:py-[64px]">
  <div class="grid gap-y-[24px] md:grid-cols-12 md:gap-x-[40px]">
    <h2
      class="md:col-span-3 font-neue-montreal-mono text-[14px] font-light uppercase triangle-after-right text-[#919191]"
      data-reveal
    >
      Reflection
    </h2>
    <div class="flex flex-col gap-[24px] md:col-span-8 md:col-start-5" data-reveal>
      <h3 class="font-neue-montreal font-medium text-[22px] md:text-[28px] leading-[1.2] text-white">
        One person, the whole stack
      </h3>
      <p class="font-neue-montreal text-[18px] md:text-[22px] leading-[1.5] text-white/80">
        This one needed range. I wrote the code, designed it
        in Figma, directed the shoot, and built the marketing that turned visitors
        into leads, the kind of spread most brands hire three or four people for.
        The cold-plunge market is full of mass-produced acrylic units; my job was
        to make a handcrafted Bali brand look and sell like the premium product it
        actually is.
      </p>
    </div>
  </div>
</section>
