---
const stages = [
  { phase: "From", title: "Broken Shopify", desc: "Unfinished, not indexed." },
  {
    phase: "Step 1",
    title: "Instant + Figma",
    desc: "Figma-driven build on Shopify Enterprise — fast to launch.",
  },
  {
    phase: "Step 2",
    title: "Bricks Builder",
    desc: "More design control as the brand matured.",
  },
  {
    phase: "Now",
    title: "WordPress · Gutenberg",
    desc: "Fully owned, editable, performance-tuned.",
  },
];
---

<ol
  class="timeline relative grid grid-cols-1 gap-y-[28px] md:grid-cols-4 md:gap-x-[24px] md:gap-y-0"
  data-reveal
>
  <span class="timeline__rail" aria-hidden="true"></span>
  {
    stages.map((s) => (
      <li class="relative pl-[24px] md:pl-0 md:pt-[24px]">
        <div class="flex flex-col gap-[8px]">
          <span class="font-neue-montreal-mono text-[12px] uppercase tracking-wide text-[#919191]">
            {s.phase}
          </span>
          <h4 class="font-neue-montreal font-medium text-[18px] md:text-[20px] leading-[1.2] text-white">
            {s.title}
          </h4>
          <p class="font-neue-montreal text-[14px] md:text-[15px] leading-[1.5] text-white/70">
            {s.desc}
          </p>
        </div>
      </li>
    ))
  }
</ol>

<style>
  /* Mobile: vertical rail down the left. */
  .timeline__rail {
    position: absolute;
    left: 0;
    top: 4px;
    bottom: 4px;
    width: 1px;
    background: rgba(255, 255, 255, 0.15);
  }

  /* Desktop: horizontal rail across the top. */
  @media (min-width: 768px) {
    .timeline__rail {
      left: 0;
      right: 0;
      top: 0;
      bottom: auto;
      width: auto;
      height: 1px;
    }
  }
</style>
