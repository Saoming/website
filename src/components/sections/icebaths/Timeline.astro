---
const stages = [
  { phase: "From", title: "Broken Shopify", desc: "Unfinished, not indexed." },
  {
    phase: "Step 1",
    title: "Instant + Figma",
    desc: "Figma-driven build on Shopify Enterprise — fast to launch.",
  },
  {
    phase: "Step 2",
    title: "Bricks Builder",
    desc: "More design control as the brand matured.",
  },
  {
    phase: "Now",
    title: "WordPress · Gutenberg",
    desc: "Fully owned, editable, performance-tuned.",
    now: true,
  },
];
---

<ol
  class="timeline list-none pl-0 grid grid-cols-1 gap-y-[28px] md:grid-cols-4 md:gap-x-[24px] md:gap-y-0"
  data-reveal
>
  {
    stages.map((s, i) => (
      <li class="timeline__item relative pl-[28px] md:pl-0 md:pt-[30px]">
        {i !== stages.length - 1 && (
          <span class="timeline__line" aria-hidden="true" />
        )}
        <span
          class:list={["timeline__dot", { "timeline__dot--now": s.now }]}
          aria-hidden="true"
        />
        <div class="flex flex-col gap-[8px]">
          <span class="font-neue-montreal-mono text-[12px] uppercase tracking-wide text-[#919191]">
            {s.phase}
          </span>
          <h4 class="font-neue-montreal font-medium text-[18px] md:text-[20px] leading-[1.2] text-white">
            {s.title}
          </h4>
          <p class="font-neue-montreal text-[14px] md:text-[15px] leading-[1.5] text-white/70">
            {s.desc}
          </p>
        </div>
      </li>
    ))
  }
</ol>

<style>
  /* Kill the default ordered-list numbering (base.css applies list-decimal). */
  .timeline {
    list-style: none;
  }

  /* Node marker */
  .timeline__dot {
    position: absolute;
    left: 0;
    top: 4px;
    width: 11px;
    height: 11px;
    border-radius: 9999px;
    background: #fff;
  }
  .timeline__dot--now {
    background: #34d399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
  }

  /* Mobile: vertical rail down the left, connecting to the next item. */
  .timeline__line {
    position: absolute;
    left: 5px;
    top: 4px;
    bottom: -28px;
    width: 1px;
    background: rgba(255, 255, 255, 0.15);
  }

  /* Desktop: horizontal rail across the top, spanning the column gap. */
  @media (min-width: 768px) {
    .timeline__dot {
      top: 0;
    }
    .timeline__line {
      left: 11px;
      right: -24px;
      top: 5px;
      bottom: auto;
      width: auto;
      height: 1px;
    }
  }
</style>
