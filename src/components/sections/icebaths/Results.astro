---
const stats = [
  { value: "54.8k", to: "54.8", decimals: "1", suffix: "k", label: "Search impressions" },
  { value: "1,210", to: "1210", decimals: "0", comma: "true", label: "Clicks to site" },
  { value: "2.2%", to: "2.2", decimals: "1", suffix: "%", label: "Click-through rate" },
  { value: "139", to: "139", decimals: "0", label: "Qualified leads" },
];
---

<section class="container py-[40px] md:py-[64px]">
  <div class="grid md:grid-cols-12 md:gap-x-[40px]">
    <div
      class="md:col-span-8 md:col-start-5 rounded-[12px] md:rounded-[20px] border border-white/15 bg-white/[0.02] p-[24px] md:p-[40px]"
      data-results
      data-reveal
    >
      {/* Header */}
      <div class="flex items-center gap-[16px] md:gap-[24px]">
        <div class="flex items-center gap-[10px]">
          <span class="results-dot" aria-hidden="true"></span>
          <span class="font-neue-montreal-mono text-[14px] uppercase tracking-wide text-white">
            Results
          </span>
        </div>
        <span class="font-neue-montreal-mono text-[14px] uppercase text-[#919191]">
          After 4 months
        </span>
      </div>

    {/* Stats */}
    <div
      class="mt-[32px] md:mt-[48px] grid grid-cols-2 gap-x-[24px] gap-y-[32px] md:grid-cols-4 md:gap-x-[32px]"
    >
      {
        stats.map((s) => (
          <div class="flex flex-col gap-[10px] border-t border-white/15 pt-[20px]">
            <span
              class="display text-[40px] md:text-[48px] leading-[1] text-white tabular-nums"
              data-count-to={s.to}
              data-count-decimals={s.decimals}
              data-count-suffix={s.suffix ?? ""}
              data-count-comma={s.comma ?? "false"}
            >
              {s.value}
            </span>
            <span class="font-neue-montreal-mono text-[13px] md:text-[14px] uppercase leading-[1.3] text-[#919191]">
              {s.label}
            </span>
          </div>
        ))
      }
      </div>
    </div>
  </div>
</section>

<style>
  /* Live "blinking" indicator — solid dot with a pulsing halo. */
  .results-dot {
    position: relative;
    width: 9px;
    height: 9px;
    border-radius: 9999px;
    background: #34d399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.7);
  }
  .results-dot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: #34d399;
    animation: results-ping 1.8s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes results-ping {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    75%,
    100% {
      transform: scale(2.8);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .results-dot::after {
      animation: none;
    }
  }
</style>

<script>
  function formatNum(value: number, decimals: number, suffix: string, comma: boolean) {
    let s = value.toFixed(decimals);
    if (comma) {
      const parts = s.split(".");
      parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");
      s = parts.join(".");
    }
    return s + suffix;
  }

  function runCounter(el: HTMLElement) {
    const target = parseFloat(el.dataset.countTo || "0");
    const decimals = parseInt(el.dataset.countDecimals || "0", 10);
    const suffix = el.dataset.countSuffix || "";
    const comma = el.dataset.countComma === "true";
    const duration = 1600;
    let startTime = 0;
    const ease = (t: number) => 1 - Math.pow(1 - t, 3); // easeOutCubic
    function frame(now: number) {
      if (!startTime) startTime = now;
      const p = Math.min(1, (now - startTime) / duration);
      el.textContent = formatNum(target * ease(p), decimals, suffix, comma);
      if (p < 1) requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }

  function initResults() {
    document.querySelectorAll<HTMLElement>("[data-results]").forEach((panel) => {
      if (panel.dataset.countReady === "1") return;
      panel.dataset.countReady = "1";

      const nums = panel.querySelectorAll<HTMLElement>("[data-count-to]");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduce || !("IntersectionObserver" in window)) return; // keep server-rendered finals

      // Reset to zero-state before the panel scrolls into view.
      nums.forEach((el) => {
        el.textContent = formatNum(
          0,
          parseInt(el.dataset.countDecimals || "0", 10),
          el.dataset.countSuffix || "",
          el.dataset.countComma === "true"
        );
      });

      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            nums.forEach((el) => runCounter(el));
            io.disconnect();
          });
        },
        { threshold: 0.3 }
      );
      io.observe(panel);
    });
  }

  if (document.readyState !== "loading") initResults();
  else document.addEventListener("DOMContentLoaded", initResults);
  document.addEventListener("astro:page-load", initResults);
</script>
