---
import { Image } from "astro:assets";
import { homeShot } from "../../utils/coverImage";
import Divider from "../common/Divider.astro";

interface ProjectData {
  id: number;
  title: string;
  headline?: string;
  slug: string;
  url: string;
  description: string;
  categories: string[];
}
interface NextLike {
  title: string;
  slug: string;
}

const { project, next, total } = Astro.props as {
  project: ProjectData;
  next: NextLike;
  total: number;
};

const shot = homeShot(project.slug);
// MacBook auto-scroll: pan the tall homepage shot inside the 16:10 screen.
// 0.625 = screen height/width (10/16). End = % of the image's own height to translate up.
const shotAR = shot.width / shot.height;
const scrollEnd = Math.max(0, Math.round((1 - 0.625 * shotAR) * 1000) / 10);
const scrollDur = Math.min(36, Math.max(8, Math.round((scrollEnd / 100) * (shot.height / shot.width) * 5)));
const idLabel = `/0${project.id}`;
const totalLabel = `0${total}`;
---

<article class="overflow-clip" data-cs-detail>
  {/* ── Hero ───────────────────────────────────────────────── */}
  <header class="container pt-[80px] md:pt-[120px] lg:pt-[160px] pb-[48px] lg:pb-[80px]">
    <div
      class="flex flex-col gap-[6px] md:flex-row md:items-center md:justify-between font-neue-montreal-mono text-[14px] text-[#919191] uppercase"
    >
      <span data-reveal>Case Studies {idLabel}</span>
      <span data-reveal class="flex items-center gap-[10px]">
        {
          project.categories.map((category, i) => (
            <span>
              {category}
              {i !== project.categories.length - 1 ? " —" : ""}
            </span>
          ))
        }
      </span>
    </div>

    <h1
      class="display leading-[0.95] text-[clamp(32px,6vw,72px)] mt-[24px] md:mt-[40px] [overflow-wrap:break-word]"
      data-reveal
    >
      {project.headline ?? project.title}
    </h1>

    <p
      class="font-pp-seiko text-[24px] md:text-[32px] lg:text-[40px] leading-[1.15] max-w-[820px] mt-[32px] md:mt-[56px] text-white/90"
      data-reveal
    >
      {project.description}
    </p>
  </header>

  {/* ── Meta (only what the data actually holds) ───────────── */}
  <Divider caseStudies={true} />
  <section
    class="container grid grid-cols-2 md:grid-cols-4 gap-y-[32px] gap-x-[24px] py-[40px] md:py-[64px] font-neue-montreal-mono"
  >
    <div class="flex flex-col gap-[12px]" data-reveal>
      <h2 class="text-[14px] font-light uppercase triangle-text-after text-[#919191]">
        Discipline
      </h2>
      <p class="text-[16px] md:text-[18px]">
        {project.categories.join(" / ")}
      </p>
    </div>
    <div class="flex flex-col gap-[12px]" data-reveal>
      <h2 class="text-[14px] font-light uppercase triangle-text-after text-[#919191]">
        Project
      </h2>
      <p class="text-[16px] md:text-[18px]">Case Study {idLabel}</p>
    </div>
  </section>

  {/* ── Live site — MacBook mockup ─────────────────────────── */}
  <section class="container pt-[24px] pb-[80px] md:pt-[40px] md:pb-[120px]">
    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="macbook group block mx-auto max-w-[1040px]"
      aria-label={`Visit the ${project.title} live site (opens in a new tab)`}
      data-reveal
    >
      <div class="macbook__lid">
        <div
          class="macbook__screen"
          style={`--mb-end:-${scrollEnd}%;--mb-dur:${scrollDur}s`}
        >
          <Image
            src={shot}
            alt={`${project.title} homepage`}
            loading="lazy"
            class="macbook__img"
          />
        </div>
      </div>
      <div class="macbook__base"><span class="macbook__notch"></span></div>
      <span
        class="block text-center mt-[20px] md:mt-[28px] font-neue-montreal-mono text-[14px] uppercase text-[#919191] triangle-text-before transition-transform duration-300 ease-out group-hover:translate-x-1"
      >
        Visit live site ↗
      </span>
    </a>
  </section>

  {/* ── Next case + All work ───────────────────────────────── */}
  <Divider caseStudies={true} />
  <section class="container py-[64px] md:py-[120px]">
    <a
      href={`/case-studies/${next.slug}/`}
      class="group block"
      aria-label={`Next case study: ${next.title}`}
      data-reveal
    >
      <span
        class="font-neue-montreal-mono text-[14px] text-[#919191] uppercase triangle-text-after"
        >Next case</span
      >
      <div class="flex items-end justify-between gap-[24px] mt-[12px] md:mt-[24px]">
        <h2
          class="font-pp-seiko font-thin uppercase leading-[0.9] text-[clamp(32px,9vw,120px)] min-w-0 [overflow-wrap:break-word] transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:translate-x-[16px]"
        >
          {next.title}
        </h2>
        <span
          class="font-pp-seiko text-[40px] md:text-[64px] shrink-0 transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:translate-x-[16px]"
          aria-hidden="true">→</span
        >
      </div>
    </a>

    <a
      href="/case-studies"
      class="inline-flex items-center gap-[10px] mt-[48px] md:mt-[72px] font-neue-montreal-mono text-[14px] uppercase triangle-text-before"
      data-reveal
    >
      All work
      <span class="text-[#919191]">{totalLabel}</span>
    </a>
  </section>
</article>

<style>
  /* MacBook mockup — pure CSS frame (silver aluminum), 16:10 screen. */
  .macbook__lid {
    padding: clamp(5px, 0.8vw, 10px);
    border-radius: clamp(14px, 1.8vw, 24px);
    background: linear-gradient(150deg, #ececee 0%, #cfd2d6 38%, #b6babf 55%, #dde0e3 100%);
    box-shadow:
      0 30px 60px -24px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      inset 0 0 0 1px rgba(0, 0, 0, 0.08);
  }
  .macbook__screen {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border: clamp(5px, 0.8vw, 10px) solid #0c0d10;
    border-radius: clamp(7px, 1vw, 14px);
    background: #000;
  }
  .macbook__img {
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    width: 100%;
    height: auto;
    animation: macbook-scroll var(--mb-dur, 20s) ease-in-out infinite alternate;
  }
  /* Pause the scroll on hover so the page can be read. */
  .macbook:hover .macbook__img {
    animation-play-state: paused;
  }
  @keyframes macbook-scroll {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(var(--mb-end, 0%));
    }
  }
  .macbook__base {
    position: relative;
    width: 116%;
    margin: 0 -8%;
    height: clamp(10px, 1.4vw, 16px);
    background: linear-gradient(180deg, #e6e8ea 0%, #c5c9ce 45%, #a9aeb4 78%, #cfd2d6 100%);
    border-radius: 0 0 clamp(9px, 1.1vw, 14px) clamp(9px, 1.1vw, 14px);
    box-shadow: 0 12px 20px -12px rgba(0, 0, 0, 0.45);
  }
  .macbook__notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(80px, 10vw, 130px);
    height: clamp(5px, 0.7vw, 9px);
    background: linear-gradient(180deg, #9aa0a6 0%, #c2c6cb 100%);
    border-radius: 0 0 clamp(7px, 0.9vw, 11px) clamp(7px, 0.9vw, 11px);
  }
  @media (prefers-reduced-motion: reduce) {
    .macbook__img {
      animation: none !important;
      transform: none !important;
    }
  }

  /* Scroll-reveal — brand-consistent eased motion, not locomotive/WebGL.
     Hidden state applies ONLY once JS arms the root, so no-JS keeps content. */
  .cs-reveal-ready [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.8s cubic-bezier(0.76, 0, 0.24, 1),
      transform 0.8s cubic-bezier(0.76, 0, 0.24, 1);
  }
  .cs-reveal-ready [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  function initCaseStudyReveal() {
    const root = document.querySelector<HTMLElement>("[data-cs-detail]");
    if (!root || root.dataset.csReady === "1") return;
    root.dataset.csReady = "1";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    const targets = root.querySelectorAll<HTMLElement>("[data-reveal]");
    if (reduce.matches || !("IntersectionObserver" in window)) return; // leave visible

    root.classList.add("cs-reveal-ready");
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
    );
    targets.forEach((el) => io.observe(el));
  }

  if (document.readyState !== "loading") initCaseStudyReveal();
  else document.addEventListener("DOMContentLoaded", initCaseStudyReveal);
  document.addEventListener("astro:page-load", initCaseStudyReveal);
</script>
