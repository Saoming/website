---
import { Image } from "astro:assets";
import { coverImage } from "../../utils/coverImage";
import Divider from "../common/Divider.astro";

interface ProjectData {
  id: number;
  title: string;
  slug: string;
  description: string;
  categories: string[];
}
interface NextLike {
  title: string;
  slug: string;
}

const { project, next, total } = Astro.props as {
  project: ProjectData;
  next: NextLike;
  total: number;
};

const cover = coverImage(project.slug);
const idLabel = `/0${project.id}`;
const totalLabel = `0${total}`;
// ponytail: only the cover exists today, so every framed slot reuses it.
// Swap each `cover` for a real shot (or bind to projectImages) when assets land.
const gallery = [cover, cover, cover];
---

<article class="overflow-clip" data-cs-detail>
  {/* ── Hero ───────────────────────────────────────────────── */}
  <header class="container pt-[80px] md:pt-[120px] lg:pt-[160px] pb-[48px] lg:pb-[80px]">
    <div
      class="flex flex-col gap-[6px] md:flex-row md:items-center md:justify-between font-neue-montreal-mono text-[14px] text-[#919191] uppercase"
    >
      <span data-reveal>Case Studies {idLabel}</span>
      <span data-reveal class="flex items-center gap-[10px]">
        {
          project.categories.map((category, i) => (
            <span>
              {category}
              {i !== project.categories.length - 1 ? " —" : ""}
            </span>
          ))
        }
      </span>
    </div>

    <h1
      class="display leading-[0.9] text-[clamp(36px,11vw,150px)] mt-[24px] md:mt-[40px] [overflow-wrap:break-word]"
      data-reveal
    >
      {project.title}
    </h1>

    <p
      class="font-pp-seiko text-[24px] md:text-[32px] lg:text-[40px] leading-[1.15] max-w-[820px] mt-[32px] md:mt-[56px] text-white/90"
      data-reveal
    >
      {project.description}
    </p>
  </header>

  {/* ── Meta (only what the data actually holds) ───────────── */}
  <Divider caseStudies={true} />
  <section
    class="container grid grid-cols-2 md:grid-cols-4 gap-y-[32px] gap-x-[24px] py-[40px] md:py-[64px] font-neue-montreal-mono"
  >
    <div class="flex flex-col gap-[12px]" data-reveal>
      <h2 class="text-[14px] font-light uppercase triangle-text-after text-[#919191]">
        Discipline
      </h2>
      <p class="text-[16px] md:text-[18px]">
        {project.categories.join(" / ")}
      </p>
    </div>
    <div class="flex flex-col gap-[12px]" data-reveal>
      <h2 class="text-[14px] font-light uppercase triangle-text-after text-[#919191]">
        Project
      </h2>
      <p class="text-[16px] md:text-[18px]">Case Study {idLabel}</p>
    </div>
  </section>

  {/* ── Imagery — reference rhythm: full-bleed hero, 3-up, full ── */}
  <section class="container flex flex-col gap-[16px] md:gap-[24px] pb-[80px] md:pb-[120px]">
    <figure class="overflow-hidden rounded-[14px]" data-reveal>
      <Image
        src={cover}
        alt={project.title}
        loading="eager"
        class="w-full object-cover aspect-[16/10]"
      />
    </figure>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-[16px] md:gap-[24px]">
      {
        gallery.map((img, i) => (
          <figure
            class="overflow-hidden rounded-[14px]"
            data-reveal
            style={`transition-delay:${i * 90}ms`}
          >
            <Image
              src={img}
              alt=""
              loading="lazy"
              class="w-full h-full object-cover aspect-[4/5]"
            />
          </figure>
        ))
      }
    </div>

    <figure class="overflow-hidden rounded-[14px]" data-reveal>
      <Image
        src={cover}
        alt=""
        loading="lazy"
        class="w-full object-cover aspect-[16/10]"
      />
    </figure>
  </section>

  {/* ── Next case + All work ───────────────────────────────── */}
  <Divider caseStudies={true} />
  <section class="container py-[64px] md:py-[120px]">
    <a
      href={`/case-studies/${next.slug}/`}
      class="group block"
      aria-label={`Next case study: ${next.title}`}
      data-reveal
    >
      <span
        class="font-neue-montreal-mono text-[14px] text-[#919191] uppercase triangle-text-after"
        >Next case</span
      >
      <div class="flex items-end justify-between gap-[24px] mt-[12px] md:mt-[24px]">
        <h2
          class="font-pp-seiko font-thin uppercase leading-[0.9] text-[clamp(32px,9vw,120px)] min-w-0 [overflow-wrap:break-word] transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:translate-x-[16px]"
        >
          {next.title}
        </h2>
        <span
          class="font-pp-seiko text-[40px] md:text-[64px] shrink-0 transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:translate-x-[16px]"
          aria-hidden="true">→</span
        >
      </div>
    </a>

    <a
      href="/case-studies"
      class="inline-flex items-center gap-[10px] mt-[48px] md:mt-[72px] font-neue-montreal-mono text-[14px] uppercase triangle-text-before"
      data-reveal
    >
      All work
      <span class="text-[#919191]">{totalLabel}</span>
    </a>
  </section>
</article>

<style>
  /* Scroll-reveal — brand-consistent eased motion, not locomotive/WebGL.
     Hidden state applies ONLY once JS arms the root, so no-JS keeps content. */
  .cs-reveal-ready [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.8s cubic-bezier(0.76, 0, 0.24, 1),
      transform 0.8s cubic-bezier(0.76, 0, 0.24, 1);
  }
  .cs-reveal-ready [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  function initCaseStudyReveal() {
    const root = document.querySelector<HTMLElement>("[data-cs-detail]");
    if (!root || root.dataset.csReady === "1") return;
    root.dataset.csReady = "1";

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    const targets = root.querySelectorAll<HTMLElement>("[data-reveal]");
    if (reduce.matches || !("IntersectionObserver" in window)) return; // leave visible

    root.classList.add("cs-reveal-ready");
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
    );
    targets.forEach((el) => io.observe(el));
  }

  if (document.readyState !== "loading") initCaseStudyReveal();
  else document.addEventListener("DOMContentLoaded", initCaseStudyReveal);
  document.addEventListener("astro:page-load", initCaseStudyReveal);
</script>
