---
import Socials from "../navigation/Socials.astro";
---

<section class="lg:pt-[135px] lg:pb-[80px] container flex flex-col">
  <div
    class="flex flex-col md:flex-row items-start md:items-center justify-between lg:px-[40px] font-neue-montreal-mono flow zero-flow mb-[40px] lg:mb-[184px]"
  >
    <span class="text-[14px] font-light uppercase">Based in Bali</span>
    <span class="text-[14px] font-light uppercase">Frontend</span>
    <span class="text-[14px] font-light max-w-[353px] uppercase">
      Expert-level WordPress — engineered, not just assembled. FOCUSED ON
      IMPROVING CODE QUALITY, AND ACCESSIBILITY. WORKING AS FRONTEND DEV
      SINCE 2016 — EX CODEABLE.</span
    >
  </div>

  <div class="pb-[80px] text-center">
    <h1 class="text-[40px] lg:text-[88px] display uppercase">
      Samuel Tirtawidjaja
    </h1>
    <p
      class="text-[38px] lg:text-[86px] uppercase triangle-text-before triangle-text-after"
    >
      SR WP Expert
    </p>
  </div>

  <Socials />
</section>
