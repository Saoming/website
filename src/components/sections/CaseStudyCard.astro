---
import { Image } from "astro:assets";

interface Props {
  id: number;
  slug: string;
  title: string;
  categories: string[];
  image: ImageMetadata;
}

const { id, slug, title, categories, image } = Astro.props;
---

<a href={`/case-studies/${slug}/`} class="group flex flex-col w-full">
  <div class="w-full overflow-hidden">
    <Image
      src={image}
      alt={title}
      class="w-full h-auto object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
    />
  </div>

  <div
    class="flex items-start justify-between gap-[10px] p-[10px] font-neue-montreal-mono text-[14px] text-[#919191]"
  >
    <span class="whitespace-nowrap">Case Studies /0{id}</span>
    <span class="uppercase text-right">{categories.join(" — ")}</span>
  </div>

  <div class="flex flex-col gap-[8px] p-[10px]">
    <div class="flex items-center justify-between text-[24px] lg:text-[28px] text-white">
      <span class="font-neue-montreal">{title}</span>
      <span
        class="font-pp-seiko transition-transform duration-300 ease-out group-hover:translate-x-1"
        >→</span
      >
    </div>
    <div class="border-t border-white/20"></div>
  </div>
</a>
