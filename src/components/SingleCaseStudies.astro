---
const { id, slug, title, categories, index } = Astro.props;
---

<div role="menuitem" class="container py-[28px]">
  <a
    href={`/case-studies/${slug}/`}
    class="flex flex-col items-start text-left md:grid md:grid-cols-12 md:items-center md:gap-x-[24px] flow zero-flow"
    data-cs-row
    data-cs-index={index}
  >
    <span
      class="font-neue-montreal-mono text-[14px] text-[#919191] md:col-span-2"
      >Case Studies /0{id}</span
    >
    <h2
      class="font-pp-seiko text-[40px] md:text-[48px] triangle-text-after md:col-span-6"
    >
      {title}
    </h2>
    <div class="flex items-center gap-[10px] md:col-span-3">
      {
        categories &&
          categories.map((category, i) => (
            <span class="uppercase text-[#919191] text-[14px] font-neue-montreal-mono">
              {category}
              {i !== categories.length - 1 ? "—" : ""}
            </span>
          ))
      }
    </div>
    <div class="font-pp-seiko text-[28px] md:col-span-1 md:justify-self-end">
      →
    </div>
  </a>
</div>
