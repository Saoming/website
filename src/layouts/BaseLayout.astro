---
import "../styles/index.css";
import Head from "../components/seo/Head.astro";
import Loader from "../components/common/Loader.astro";
import Header from "../components/navigation/Header.astro";
import Footer from "../components/navigation/Footer.astro";
import SimpleFooter from "../components/navigation/SimpleFooter.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article";
  publishedTime?: string;
  noindex?: boolean;
  /** "full" = homepage/article footer (CTA + clock); "simple" = socials + copyright. */
  footer?: "full" | "simple";
}

const {
  title,
  description,
  image,
  imageAlt,
  type,
  publishedTime,
  noindex,
  footer = "full",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <Head {title} {description} {image} {imageAlt} {type} {publishedTime} {noindex} />
  </head>
  <body class="text-white bg-background">
    <Loader />
    <Header />
    <main>
      <slot />
    </main>
    {footer === "simple" ? <SimpleFooter /> : <Footer />}
  </body>
</html>
